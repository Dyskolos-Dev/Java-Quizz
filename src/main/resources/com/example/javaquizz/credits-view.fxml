<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER_LEFT" spacing="10.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.javaquizz.CreditsController"
      style="-fx-background-color: #111827;">
    <padding>
        <Insets top="18.0" right="20.0" bottom="18.0" left="20.0"/>
    </padding>

    <Label text="Credits" style="-fx-text-fill: #f8fafc; -fx-font-size: 22px; -fx-font-weight: bold;"/>
    <Label text="Developpeurs:" style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px;"/>

    <Label text="Dyskolos" style="-fx-text-fill: #f8fafc; -fx-font-size: 15px;"/>
    <Hyperlink fx:id="dyskolosLink" text="https://dyskolos.fr" onAction="#onOpenDyskolos"/>

    <Label text="PrettyFlacko" style="-fx-text-fill: #f8fafc; -fx-font-size: 15px;"/>
    <Hyperlink fx:id="prettyFlackoLink" text="https://prettyflacko.fr" onAction="#onOpenPrettyFlacko"/>

    <Button text="Fermer" onAction="#onClose" style="-fx-font-size: 14px; -fx-padding: 6 14 6 14;"/>
</VBox>

