<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.javaquizz.HelloController"
            style="-fx-background-color: #0f172a;">

    <center>
        <AnchorPane>
            <children>
                <ImageView fitWidth="780.0" fitHeight="460.0" preserveRatio="false" opacity="0.92"
                           AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                           AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
                    <image>
                        <Image url="@images/kikihouse.png"/>
                    </image>
                </ImageView>

                <MenuButton text="Menu" style="-fx-font-size: 14px;"
                            AnchorPane.topAnchor="12.0" AnchorPane.rightAnchor="12.0">
                    <items>
                        <MenuItem text="Recommencer" onAction="#onRestartClick"/>
                        <MenuItem text="Credits" onAction="#onCreditsClick"/>
                        <MenuItem text="Quitter" onAction="#onQuitClick"/>
                    </items>
                </MenuButton>

                <Label text="Briefing d'introduction"
                       style="-fx-font-size: 24px; -fx-text-fill: white; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.65), 8, 0.2, 0, 2);"
                       AnchorPane.topAnchor="12.0" AnchorPane.leftAnchor="24.0"/>

                <HBox spacing="12.0" alignment="BOTTOM_LEFT"
                      AnchorPane.leftAnchor="18.0" AnchorPane.bottomAnchor="40.0">
                    <ImageView fitWidth="185.0" fitHeight="185.0" preserveRatio="true">
                        <image>
                            <Image url="@images/guide.png"/>
                        </image>
                    </ImageView>

                    <VBox spacing="8.0" alignment="BOTTOM_LEFT">
                        <Label fx:id="dialogueText"
                               wrapText="true"
                               prefWidth="500.0"
                               style="-fx-font-size: 16px; -fx-text-fill: #0f172a; -fx-background-color: #f8fafc; -fx-background-radius: 18 18 18 4; -fx-border-color: #1e293b; -fx-border-radius: 18 18 18 4; -fx-padding: 14 16 14 16;"/>

                        <Button fx:id="nextButton"
                                text="Suivant"
                                onAction="#onNextButtonClick"
                                style="-fx-font-size: 15px; -fx-padding: 8 18 8 18; -fx-background-radius: 12;"/>
                    </VBox>
                </HBox>
            </children>
        </AnchorPane>
    </center>
</BorderPane>
