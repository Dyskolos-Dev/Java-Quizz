<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.javaquizz.QuizController"
            style="-fx-background-color: #111827;">
    <center>
        <AnchorPane>
            <children>
                <ImageView fx:id="backgroundImageView" fitWidth="780.0" fitHeight="460.0" preserveRatio="false" opacity="0.95"
                           AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                           AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
                    <image>
                        <Image url="@images/kikihouse.png"/>
                    </image>
                </ImageView>

                <MenuButton fx:id="gameMenuButton" text="Menu" style="-fx-font-size: 14px;"
                            AnchorPane.topAnchor="12.0" AnchorPane.rightAnchor="12.0">
                    <items>
                        <MenuItem text="Recommencer" onAction="#onRestartClick"/>
                        <MenuItem text="Credits" onAction="#onCreditsClick"/>
                        <MenuItem text="Quitter" onAction="#onQuitClick"/>
                    </items>
                </MenuButton>

                <VBox fx:id="successBox" alignment="CENTER" spacing="14.0"
                      style="-fx-background-color: rgba(15,23,42,0.82); -fx-background-radius: 14; -fx-padding: 18;"
                      AnchorPane.leftAnchor="110.0" AnchorPane.rightAnchor="110.0" AnchorPane.topAnchor="62.0">
                    <Label text="Bravo tu as reussi le quiz"
                           style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #f8fafc;"/>
                    <Label text="Code de desamorssage : 1406"
                           style="-fx-font-size: 22px; -fx-text-fill: #e2e8f0;"/>
                    <Button text="Reparler a Kiki"
                            onAction="#onTalkToKikiClick"
                            style="-fx-font-size: 16px; -fx-padding: 8 18 8 18;"/>
                </VBox>

                <VBox fx:id="finalDialogueBox" visible="false" managed="false"
                      AnchorPane.leftAnchor="18.0" AnchorPane.rightAnchor="18.0" AnchorPane.bottomAnchor="62.0">
                    <HBox spacing="12.0" alignment="BOTTOM_LEFT">
                        <ImageView fitWidth="185.0" fitHeight="185.0" preserveRatio="true">
                            <image>
                                <Image url="@images/guide.png"/>
                            </image>
                        </ImageView>

                        <VBox spacing="8.0" alignment="BOTTOM_LEFT">
                            <Label fx:id="finalDialogueText"
                                   wrapText="true"
                                   prefWidth="500.0"
                                   style="-fx-font-size: 16px; -fx-text-fill: #0f172a; -fx-background-color: #f8fafc; -fx-background-radius: 18 18 18 4; -fx-border-color: #1e293b; -fx-border-radius: 18 18 18 4; -fx-padding: 14 16 14 16;"/>
                            <Button fx:id="finalNextButton"
                                    text="Suivant"
                                    onAction="#onFinalNextClick"
                                    style="-fx-font-size: 15px; -fx-padding: 8 18 8 18; -fx-background-radius: 12;"/>

                            <VBox fx:id="defuseBox" visible="false" managed="false" spacing="6.0"
                                  style="-fx-background-color: rgba(15,23,42,0.88); -fx-background-radius: 12; -fx-padding: 10 12 10 12;">
                                <Label text="Entre le code de desamorssage :"
                                       style="-fx-font-size: 14px; -fx-text-fill: #f8fafc;"/>

                                <Label fx:id="defuseCodeDisplay"
                                       text="----"
                                       prefWidth="190.0"
                                       style="-fx-font-size: 22px; -fx-font-family: Consolas; -fx-alignment: center; -fx-text-fill: #f8fafc; -fx-background-color: #0f172a; -fx-background-radius: 8; -fx-padding: 8;"/>

                                <VBox fx:id="defusePad" spacing="6.0">
                                    <HBox spacing="6.0">
                                        <Button text="1" onAction="#onDigitClick" prefWidth="58.0"/>
                                        <Button text="2" onAction="#onDigitClick" prefWidth="58.0"/>
                                        <Button text="3" onAction="#onDigitClick" prefWidth="58.0"/>
                                    </HBox>
                                    <HBox spacing="6.0">
                                        <Button text="4" onAction="#onDigitClick" prefWidth="58.0"/>
                                        <Button text="5" onAction="#onDigitClick" prefWidth="58.0"/>
                                        <Button text="6" onAction="#onDigitClick" prefWidth="58.0"/>
                                    </HBox>
                                    <HBox spacing="6.0">
                                        <Button text="7" onAction="#onDigitClick" prefWidth="58.0"/>
                                        <Button text="8" onAction="#onDigitClick" prefWidth="58.0"/>
                                        <Button text="9" onAction="#onDigitClick" prefWidth="58.0"/>
                                    </HBox>
                                    <HBox spacing="6.0">
                                        <Button text="Corriger" onAction="#onBackspaceClick" prefWidth="92.0"/>
                                        <Button text="0" onAction="#onDigitClick" prefWidth="58.0"/>
                                        <Button text="Effacer" onAction="#onClearClick" prefWidth="92.0"/>
                                    </HBox>
                                </VBox>

                                <Button text="Valider" onAction="#onValidateCodeClick" prefWidth="190.0"/>
                                <Label fx:id="defuseFeedbackLabel" style="-fx-font-size: 13px; -fx-text-fill: #e2e8f0;"/>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </children>
        </AnchorPane>
    </center>
</BorderPane>
