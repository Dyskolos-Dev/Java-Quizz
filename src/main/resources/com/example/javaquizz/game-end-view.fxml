<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.javaquizz.GameEndController"
            style="-fx-background-color: #0f172a;">
    <children>
        <ImageView fitWidth="780.0" fitHeight="460.0" preserveRatio="false" opacity="0.95"
                   AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                   AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
            <image>
                <Image url="@images/kikicave.png"/>
            </image>
        </ImageView>

        <VBox alignment="CENTER" spacing="12.0"
              style="-fx-background-color: rgba(15,23,42,0.82); -fx-background-radius: 14; -fx-padding: 20;"
              AnchorPane.leftAnchor="150.0" AnchorPane.rightAnchor="150.0" AnchorPane.topAnchor="80.0">
            <Label text="Mission reussie"
                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #f8fafc;"/>
            <Label text="La bombe est desamorcee. Tout le monde est en securite."
                   wrapText="true"
                   textAlignment="CENTER"
                   alignment="CENTER"
                   style="-fx-font-size: 17px; -fx-text-fill: #cbd5e1;"/>

            <Button fx:id="restartButton"
                    text="Recommencer"
                    onAction="#onRestartClick"
                    prefWidth="220.0"
                    style="-fx-font-size: 16px; -fx-padding: 8 18 8 18;"/>
            <Button text="Credits"
                    onAction="#onCreditsClick"
                    prefWidth="220.0"
                    style="-fx-font-size: 16px; -fx-padding: 8 18 8 18;"/>
            <Button text="Quitter"
                    onAction="#onQuitClick"
                    prefWidth="220.0"
                    style="-fx-font-size: 16px; -fx-padding: 8 18 8 18;"/>
        </VBox>
    </children>
</AnchorPane>


